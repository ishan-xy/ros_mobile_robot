<?xml version="1.0" ?>
<sdf version="1.9">
  <model name="finalassembly_v3">

    <!-- BASE -->
    <link name="base_link_1">
      <inertial>
        <pose>0.08000000000000008 0.09545598293362575 0.0068908634732035455 0 0 0</pose>
        <mass>3.9409647200439992</mass>
        <inertia>
          <ixx>0.017709947701599185</ixx>
          <ixy>1.7694179454963432e-16</ixy>
          <ixz>-8.673617379884035e-19</ixz>
          <iyy>0.013743217946582138</iyy>
          <iyz>0.000759111480018366</iyz>
          <izz>0.0282437401639066</izz>
        </inertia>
      </inertial>

      <visual name="base_link_1__body1_visual">
        <geometry><mesh><scale>0.01 0.01 0.01</scale><uri>meshes/base_link_1/body1_visual.obj</uri></mesh></geometry>
      </visual>
      <visual name="base_link_1__body2_visual">
        <geometry><mesh><scale>0.01 0.01 0.01</scale><uri>meshes/base_link_1/body2_visual.obj</uri></mesh></geometry>
      </visual>
