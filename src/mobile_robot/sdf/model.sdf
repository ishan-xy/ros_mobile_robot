      </visual>

      <collision name="base_link_collision">
        <pose>0.08 0.08 0.015 0 0 0</pose>
        <geometry>
          <box><size>0.16 0.24 0.08</size></box>
        </geometry>
      </collision>
    </link>


    <!-- FRONT LEFT WHEEL -->
    <link name="front_left_wheel_1">
      <inertial>
        <pose>0.18119913055959916 0.02650941058119064 -0.058006850665017165 0 0 0</pose>
        <mass>0.23963195508574156</mass>
        <inertia>
          <ixx>6.17e-05</ixx>
          <iyy>6.17e-05</iyy>
          <izz>1.23e-04</izz>
          <ixy>0</ixy><ixz>0</ixz><iyz>0</iyz>
        </inertia>
      </inertial>
      <visual name="fl_v1">
        <geometry><mesh><scale>0.01 0.01 0.01</scale><uri>meshes/front_left_wheel_1/body1_visual.obj</uri></mesh></geometry>
      </visual>
      <visual name="fl_v2">
        <geometry><mesh><scale>0.01 0.01 0.01</scale><uri>meshes/front_left_wheel_1/body2_visual.obj</uri></mesh></geometry>
      </visual>
      <collision name="wheel_collision">
        <pose>0.1801 0.0265 -0.058 1.5708 0 1.5708</pose>
        <geometry>
          <cylinder><radius>0.032</radius><length>0.028</length></cylinder>
        </geometry>
      </collision>
    </link>


    <!-- REAR LEFT WHEEL -->
    <link name="rear_left_wheel_1">
      <inertial>
        <pose>0.18119913055959913 0.17349016693742006 -0.05800685066501671 0 0 0</pose>
        <mass>0.23963195508574073</mass>
        <inertia>
          <ixx>6.17e-05</ixx>
          <iyy>6.17e-05</iyy>
          <izz>1.23e-04</izz>
          <ixy>0</ixy><ixz>0</ixz><iyz>0</iyz>
        </inertia>
      </inertial>
      <visual name="rl_v1">
        <geometry><mesh><scale>0.01 0.01 0.01</scale><uri>meshes/rear_left_wheel_1/body1_visual.obj</uri></mesh></geometry>
      </visual>
      <visual name="rl_v2">
        <geometry><mesh><scale>0.01 0.01 0.01</scale><uri>meshes/rear_left_wheel_1/body2_visual.obj</uri></mesh></geometry>
      </visual>
      <collision name="wheel_collision">
        <pose>0.1801 0.1735 -0.058 1.5708 0 1.5708</pose>
        <geometry>
          <cylinder><radius>0.032</radius><length>0.028</length></cylinder>
        </geometry>
      </collision>
    </link>


    <!-- FRONT RIGHT WHEEL -->
    <link name="front_right_wheel_1">
      <inertial>
        <pose>-0.021199138957676604 0.02650982708653022 -0.058006862365527455 0 0 0</pose>
        <mass>0.23963191405046214</mass>
        <inertia>
          <ixx>6.17e-05</ixx>
          <iyy>6.17e-05</iyy>
          <izz>1.23e-04</izz>
          <ixy>0</ixy><ixz>0</ixz><iyz>0</iyz>
        </inertia>
      </inertial>
      <visual name="fr_v1">
        <geometry><mesh><scale>0.01 0.01 0.01</scale><uri>meshes/front_right_wheel_1/body1_visual.obj</uri></mesh></geometry>
      </visual>
      <visual name="fr_v2">
        <geometry><mesh><scale>0.01 0.01 0.01</scale><uri>meshes/front_right_wheel_1/body2_visual.obj</uri></mesh></geometry>
      </visual>
      <collision name="wheel_collision">
        <pose>-0.0201 0.0265 -0.058 1.5708 0 1.5708</pose>
        <geometry>
          <cylinder><radius>0.032</radius><length>0.028</length></cylinder>
        </geometry>
      </collision>
    </link>


    <!-- REAR RIGHT WHEEL -->
    <link name="rear_right_wheel_1">
      <inertial>
        <pose>-0.021199138957676535 0.17349058344363225 -0.05800686236552762 0 0 0</pose>
        <mass>0.23963191405045922</mass>
        <inertia>
          <ixx>6.17e-05</ixx>
          <iyy>6.17e-05</iyy>
          <izz>1.23e-04</izz>
          <ixy>0</ixy><ixz>0</ixz><iyz>0</iyz>
        </inertia>
      </inertial>
