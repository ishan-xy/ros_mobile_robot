    <!-- JOINTS -->
    <joint name="front_left_joint" type="revolute">
      <pose>0.165 0.0265 -0.058 0 0 0</pose>
      <parent>base_link_1</parent>
      <child>front_left_wheel_1</child>
      <axis>
        <xyz>1 0 0</xyz>
        <dynamics><damping>0.2</damping><friction>0.05</friction></dynamics>
        <limit><lower>-1000000</lower><upper>1000000</upper></limit>
      </axis>
    </joint>

    <joint name="rear_left_joint" type="revolute">
      <pose>0.165 0.1735 -0.058 0 0 0</pose>
      <parent>base_link_1</parent>
      <child>rear_left_wheel_1</child>
      <axis>
        <xyz>1 0 0</xyz>
        <dynamics><damping>0.2</damping><friction>0.05</friction></dynamics>
        <limit><lower>-1000000</lower><upper>1000000</upper></limit>
      </axis>
    </joint>

    <joint name="front_right_joint" type="revolute">
      <pose>-0.005 0.0265 -0.058 0 0 0</pose>
      <parent>base_link_1</parent>
      <child>front_right_wheel_1</child>
      <axis>
        <xyz>1 0 0</xyz>
        <dynamics><damping>0.2</damping><friction>0.05</friction></dynamics>
        <limit><lower>-1000000</lower><upper>1000000</upper></limit>
      </axis>
    </joint>

    <joint name="rear_right_joint" type="revolute">
      <pose>-0.005 0.1735 -0.058 0 0 0</pose>
      <parent>base_link_1</parent>
      <child>rear_right_wheel_1</child>
      <axis>
        <xyz>1 0 0</xyz>
        <dynamics><damping>0.2</damping><friction>0.05</friction></dynamics>
        <limit><lower>-1000000</lower><upper>1000000</upper></limit>
      </axis>
    </joint>


    <!-- DIFF DRIVE PLUGIN -->
    <plugin filename="libignition-gazebo-diff-drive-system.so"
            name="ignition::gazebo::systems::DiffDrive">

      <left_joint>front_left_joint</left_joint>
      <left_joint>rear_left_joint</left_joint>

      <right_joint>front_right_joint</right_joint>
      <right_joint>rear_right_joint</right_joint>

      <wheel_separation>0.2002</wheel_separation>
      <wheel_radius>0.032</wheel_radius>
      <max_linear_velocity>0.5</max_linear_velocity>
      <max_angular_velocity>2.0</max_angular_velocity>

      <odom_publish_frequency>30</odom_publish_frequency>

      <topic>/cmd_vel</topic>
      <odom_topic>/odom</odom_topic>
      <frame_id>odom</frame_id>
      <child_frame_id>base_link_1</child_frame_id>

    </plugin>

  </model>
</sdf>