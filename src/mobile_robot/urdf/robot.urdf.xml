<?xml version="1.0"?>

<robot name="mobile_robot">

    <link name="chassis">

        <visual>
            <origin xyz="0.5 0 0.4" rpy="0 0 0"/>
            <geometry>
                <box size="2.0 1.0 0.5"/>
            </geometry>
            <material name="blue">
                <color rgba="0 0 1 1"/>
            </material>
        </visual>

        <collision>
            <origin xyz="0.5 0 0.4" rpy="0 0 0"/>
            <geometry>
                <box size="2.0 1.0 0.5"/>
            </geometry>
        </collision>

        <inertial>
            <origin xyz="0.5 0 0.4" rpy="0 0 0"/>
            <mass value="1.14395"/>
            <inertia
                ixx="0.095329"
                ixy="0.0"
                ixz="0.0"
                iyy="0.381317"
                iyz="0.0"
                izz="0.476646"/>
        </inertial>

    </link>

    <link name="front_left_wheel">
        <visual>
            <origin xyz="0 0 0" rpy="-1.5707 0 0"/>
            <geometry>
                <cylinder radius="0.4" length="0.2"/>
            </geometry>
            <material name="red">
                <color rgba="1 0 0 1"/>
            </material>
        </visual>
    </link>

    <link name="front_right_wheel">
        <visual>
            <origin xyz="0 0 0" rpy="-1.5707 0 0"/>
            <geometry>
                <cylinder radius="0.4" length="0.2"/>
            </geometry>
            <material name="red">
                <color rgba="1 0 0 1"/>
            </material>
        </visual>
    </link>

    <link name="rear_left_wheel">
        <visual>
            <origin xyz="0 0 0" rpy="-1.5707 0 0"/>
            <geometry>
                <cylinder radius="0.4" length="0.2"/>
            </geometry>
            <material name="red">
                <color rgba="1 0 0 1"/>
            </material>
        </visual>
    </link>

    <link name="rear_right_wheel">
        <visual>
            <origin xyz="0 0 0" rpy="-1.5707 0 0"/>
            <geometry>
                <cylinder radius="0.4" length="0.2"/>
            </geometry>
            <material name="red">
                <color rgba="1 0 0 1"/>
            </material>
        </visual>
    </link>

    <joint name="front_left_wheel_joint" type="continuous">
        <parent link="chassis"/>
        <child link="front_left_wheel"/>
        <origin xyz="0.5 0.6 0.0" rpy="0 0 0"/>
        <axis xyz="0 1 0"/>
    </joint>

    <joint name="front_right_wheel_joint" type="continuous">
        <parent link="chassis"/>
        <child link="front_right_wheel"/>
        <origin xyz="0.5 -0.6 0.0" rpy="0 0 0"/>
        <axis xyz="0 1 0"/>
    </joint>

    <joint name="rear_left_wheel_joint" type="continuous">
        <parent link="chassis"/>
        <child link="rear_left_wheel"/>
        <origin xyz="-0.5 0.6 0.0" rpy="0 0 0"/>
        <axis xyz="0 1 0"/>
    </joint>

    <joint name="rear_right_wheel_joint" type="continuous">
        <parent link="chassis"/>
        <child link="rear_right_wheel"/>
        <origin xyz="-0.5 -0.6 0.0" rpy="0 0 0"/>
        <axis xyz="0 1 0"/>
    </joint>

</robot>